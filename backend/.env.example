# Firebase Configuration
# Firebase Console -> Realtime Database -> copy the database URL.
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase Service Account Credentials (RECOMMENDED for production/deployment)
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# Instead of using the JSON file directly, extract these values:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternative: Path to JSON (only for local development, NOT for deployment)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-key.json

# Groq API key:
# Groq Console -> API Keys -> Create API Key.
GROQ_API_KEY=

# Fast default model. Use llama-3.3-70b-versatile for better detailed answers.
GROQ_MODEL=llama-3.3-70b-versatile
